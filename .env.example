# Salin file ini menjadi ".env" lalu isi nilainya

# Personal Access Token GitHub (scope minimal: "repo" untuk repo privat,
# atau "public_repo" jika repo-nya public). Buat di:
# https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Username/organisasi pemilik repo
GITHUB_OWNER=username-kamu

# Nama repository tujuan upload (harus sudah dibuat di GitHub)
GITHUB_REPO=nama-repo-kamu

# Branch tujuan (default: main)
GITHUB_BRANCH=main

# Folder di dalam repo tempat file disimpan (default: uploads)
GITHUB_UPLOAD_PATH=uploads
